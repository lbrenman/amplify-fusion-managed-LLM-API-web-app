{
  "name": "Aria Chat App",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Chat App",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "npm install && cp -n .env.example .env || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode"
      ]
    }
  }
}
